import json
import random
import os
import numpy as np

class EvolutionEngine:
    def __init__(self, config_path="evolution_logic.json"):
        self.config_path = config_path
        self.gen = 1
        self.mutation_factor = 0.05
        self.load_logic()

    def load_logic(self):
        if os.path.exists(self.config_path):
            with open(self.config_path, 'r') as f:
                self.logic = json.load(f)
        else:
            self.logic = {"base_fitness": 0.1, "threshold": 0.8}

    def evolve_genome(self, genome):
        """Advances genome structures via stochastic heuristic mutation."""
        mutated_genome = {}
        for key, value in genome.items():
            if isinstance(value, float):
                # Apply Gaussian noise for precision adjustment
                noise = np.random.normal(0, self.mutation_factor)
                mutated_genome[key] = value + noise
            elif isinstance(value, list):
                mutated_genome[key] = [v * (1 + random.uniform(-0.1, 0.1)) for v in value]
            else:
                mutated_genome[key] = value
        
        self.gen += 1
        return mutated_genome

    def update_status(self):
        status_file = "ai_status.json"
        with open(status_file, 'r') as f:
            status = json.load(f)
        
        status["current_gen"] = self.gen
        status["stability_index"] = min(0.999, status["stability_index"] + 0.001)
        
        with open(status_file, 'w') as f:
            json.dump(status, f, indent=4)


import os
import time
import numpy as np

class BrainCore:
    def __init__(self, history_file="brain_history.txt"):
        self.history_file = history_file
        self.synaptic_weights = np.random.rand(10, 10)
        self.learning_rate = 0.01
        self.ensure_history()

    def ensure_history(self):
        if not os.path.exists(self.history_file):
            with open(self.history_file, 'w') as f:
                f.write(f"SYSTEM_INIT: {time.time()}\n")

    def process_signal(self, input_vector):
        """Neural signal processing with Gen 1 feedback loop."""
        input_data = np.array(input_vector).reshape(-1, 1)
        if input_data.shape[0] != 10:
            input_data = np.pad(input_data, ((0, max(0, 10 - input_data.shape[0])), (0, 0)))[:10]

        activation = np.dot(self.synaptic_weights, input_data)
        output = self.activation_function(activation)
        
        self.record_state(output)
        return output.flatten().tolist()

    def activation_function(self, x):
        return np.tanh(x)

    def record_state(self, state):
        with open(self.history_file, 'a') as f:
            f.write(f"STATE_SIG: {np.mean(state)} | TIMESTAMP: {time.time()}\n")

    def adaptive_tuning(self, error_signal):
        """Adjusts weights based on gen-1 error gradients."""
        adjustment = error_signal * self.learning_rate
        self.synaptic_weights += adjustment
        self.learning_rate *= 0.999  # Stability decay


